#!python3

import subprocess
import uuid


PLATFORM: dict[str, tuple[str, str]] = {
    'arm64': ('linux/arm64', 'arm64v8'),
    'arm32': ('linux/arm/v7', 'arm32v7'),
    'x86': ('linux/386', 'i386')
}


def crossdk(platform: str, image: str, options: list[str]):
    name = str(uuid.uuid1())

    try:
        command = ['docker', 'run', '--name', name, *options, '--platform', f'{PLATFORM[platform][0]}', f'{PLATFORM[platform][1]}/{image}']
        subprocess.run(command)
        command = ['docker', 'cp', f'{name}:/', 'fs']
        subprocess.run(command, check=True)
    finally:
        command = ['docker', 'rm', name]
        subprocess.run(command, stdout=subprocess.DEVNULL)


def main():
    from argparse import ArgumentParser
    parser = ArgumentParser()
    parser.add_argument('--image', '-i', default='ubuntu')
    parser.add_argument('platform', choices=PLATFORM.keys())
    args = parser.parse_args()

    crossdk(args.platform, args.image, ['-it'])


if __name__ == '__main__':
    main()
