#!/bin/sh

npm init -y
npm install --save-dev typescript @types/frida-gum
npm install --save-dev frida-compile
npx tsc --init
npm pkg delete 'scripts'
npm pkg set 'scripts.prelocal'='npx frida-compile trace.ts -o trace.js'
npm pkg set 'scripts.local'='frida -l trace.js --'
npm pkg set 'scripts.preandroid'='npx frida-compile trace.ts -o trace.js'
npm pkg set 'scripts.android'='frida -l trace.js -U -f'
touch trace.ts
