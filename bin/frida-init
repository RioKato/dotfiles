#!/bin/sh

npm init -y
npm install --save-dev typescript @types/frida-gum
npm install --save-dev frida-compile
npx tsc --init
npm pkg delete 'scripts'
npm pkg set 'scripts.build'='npx frida-compile trace.ts -o trace.js'
npm pkg set 'scripts.frida'='frida -l trace.js --'
npm pkg set 'scripts.prelocal'='npm run build'
npm pkg set 'scripts.local'='npm run frida'
npm pkg set 'scripts.preandroid'='npm run build'
npm pkg set 'scripts.android'='npm run frida -U -f'
mkdir src
