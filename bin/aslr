#!/bin/sh

if [ $(id -u) -ne 0 ]
then
  SUDO='sudo'
fi

BIT=$(cat /proc/sys/kernel/randomize_va_space)

if [ $BIT -gt 0 ]
then
  NEW_BIT=0
else
  NEW_BIT=2
fi

CMD="echo $NEW_BIT | $SUDO tee /proc/sys/kernel/randomize_va_space > /dev/null"

eval $CMD || {
  echo error
  exit 1
}

if [ $BIT -eq 0 ]
then
  echo enabled
else
  echo disabled
fi

exit 0
