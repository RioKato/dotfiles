#!/bin/sh

{ [ -z "$TMUX" ] || [ "$FZF_TMUX" -eq 0 ]; } && exit 1

__fzfcmd() {
  echo "fzf-tmux ${FZF_TMUX_OPTS:--d${FZF_TMUX_HEIGHT:-40%}} -- "
}

__select_ip() {
  { ip -o address show | awk '{print $2, substr($4, 0, index($4, "/")-1)}'; getent hosts | awk '{print $2, $1}'; } | \
    sort -u | \
    FZF_DEFAULT_OPTS="--height ${FZF_TMUX_HEIGHT:-40%} --reverse --bind=ctrl-z:ignore ${FZF_DEFAULT_OPTS-}" $(__fzfcmd) --bind 'enter:become(echo -n {2})'
}

tmux send $(__select_ip)
exit 0
