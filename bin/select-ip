#!/bin/sh

[ -z "$TMUX" ] && exit 1

__fzfcmd() {
  echo "fzf-tmux $FZF_TMUX_OPTS"
}

{ ip -o -4 address show | awk '{print $2, substr($4, 0, index($4, "/")-1)}'; getent hosts | awk '{print $2, $1}'; } | \
  sort -u | \
  FZF_DEFAULT_OPTS="--bind=ctrl-z:ignore ${FZF_DEFAULT_OPTS-}" $(__fzfcmd) --bind 'enter:become(echo -n {2})'

