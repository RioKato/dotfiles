#!/bin/bash

deps() {
  readelf -d $1 | awk -v bin=`basename $1` '{if ($2 == "(NEEDED)") print bin, substr($5, 2, length($5) - 2);}'
}

deps_r() {
  find -L $1 -type f -exec bu -d {} \; 2> /dev/null
}

syms() {
  nm -D --defined-only $1 | awk -v bin=$1 '{print bin, "defined", $3}'
  nm -D -u $1 | awk -v bin=$1 '{print bin, "undefined", $2}'
}

syms_r() {
  find $1 -type f -exec bu -s {} \; 2> /dev/null
}

strings_r() {
  find $1 -type f -exec strings -f {} \; 2> /dev/null
}

while getopts "d:e:s:t:x:" OPTION; do
  case $OPTION in
    d)
      deps $OPTARG
      exit 0
      ;;
    e)
      deps_r $OPTARG
      exit 0
      ;;
    s)
      syms $OPTARG
      exit 0
      ;;
    t)
      syms_r $OPTARG
      exit 0
      ;;
    x)
      strings_r $OPTARG
      exit 0
      ;;
  esac
done

CMDNAME=`basename $0`
echo "Usage: $CMDNAME [-d bin] [-e dir] [-s bin] [-t dir] [-x dir]" 1>&2
exit 1
